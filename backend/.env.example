APP_ENV=development
JWT_SECRET=local-dev-secret
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me
AUTO_CREATE_INITIAL_ADMIN=false

# 本地直接 uvicorn 启动建议先用 memory，避免依赖 Docker Compose 的 postgres 主机名。
STORE_BACKEND=memory

# 如果你本机已经启动了 Postgres，再改成 STORE_BACKEND=postgres 并使用 localhost。
DATABASE_URL=postgresql+asyncpg://xiaozhi:xiaozhi@localhost:5432/xiaozhi_mcp_hub
REDIS_URL=redis://localhost:6379/0
